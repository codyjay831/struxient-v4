# PostgreSQL connection (SSL params as required by your host)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth v5 — required. Used to encrypt/decrypt the JWT session cookie.
# Generate once per environment and keep stable across restarts:
#   openssl rand -base64 32
#
# If you change AUTH_SECRET, existing session cookies become unreadable. Clear site data /
# cookies for this origin (e.g. localhost), then sign in again. Optionally delete `.next`
# if the dev server cache looks wrong after env changes.
#
# Canonical name is AUTH_SECRET. NEXTAUTH_SECRET is supported only as a legacy fallback
# during migration from NextAuth v4; do not set both to different values.
AUTH_SECRET=""

# Used only by prisma/seed.ts (never commit real passwords)
SEED_OWNER_EMAIL="admin@struxient.local"
SEED_OWNER_PASSWORD=""
SEED_ORG_NAME="Struxient Dev"
SEED_ORG_SLUG="struxient-dev"

# --- Phase 11: portal file uploads (private storage) ---
# Development / non-production: files are stored under PORTAL_UPLOAD_LOCAL_ROOT (default: ./.data/portal-uploads).
# PORTAL_UPLOAD_LOCAL_ROOT="C:\\path\\to\\private\\portal-uploads"
#
# Production: set all of the following (local disk provider is not used when NODE_ENV=production).
# PORTAL_UPLOAD_S3_BUCKET="your-private-bucket"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
