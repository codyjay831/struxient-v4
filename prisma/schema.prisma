generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  OFFICE
  SALES
  MEMBER
  CREW_LEAD
  FIELD_WORKER
}

enum CustomerKind {
  PERSON
  COMPANY
  UNKNOWN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CustomerContactType {
  EMAIL
  PHONE
  MOBILE
  OTHER
}

enum OpportunityStatus {
  NEW
  QUALIFIED
  INFO_GATHERING
  SITE_VISIT_NEEDED
  QUOTE_DRAFT_READY
  QUOTE_DRAFT_CREATED
  LOST
  NO_QUOTE
  ARCHIVED
}

enum QuoteStatus {
  DRAFT
  MISSING_INFO
  NEEDS_REVIEW
  READY_TO_SEND
  SENT
  ACCEPTED
  ACTIVATED
  REVISED
  DECLINED
}

enum JobStatus {
  WORK_PLAN_REVIEW
  ACTIVE
  COMPLETED
  PAUSED
  CANCELED
}

enum JobTaskStatus {
  NOT_STARTED
  READY
  IN_PROGRESS
  COMPLETE
  BLOCKED
}

enum ScheduledWorkStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum ScheduledWorkType {
  JOB_TASK
  JOB_VISIT
}

enum CustomerPortalSubmissionType {
  GENERAL_REQUEST
  AVAILABILITY_NOTE
  APPOINTMENT_CONFIRMATION
  FILE_UPLOAD
}

enum CustomerPortalSubmissionAttachmentStatus {
  STORED
  REJECTED
  DELETED
}

enum CustomerPortalSubmissionStatus {
  NEW
  REVIEWED
  ACTIONED
  DISMISSED
}

enum JobEvidenceStatus {
  CANDIDATE
  ACCEPTED
  REJECTED
}

enum QuoteLineMode {
  REQUIRED
  OPTIONAL
  ALTERNATE
  ALLOWANCE
  REMOVED
}

enum PricingMode {
  FIXED_PRICE
  PRICE_ON_REQUEST
  ALLOWANCE
  INCLUDED
  NO_CHARGE
}

/// Quote workspace internal prep only. Line-item execution uses QuoteLineExecutionStage / QuoteLineExecutionTask.
enum QuoteTaskKind {
  QUOTE_PREP
}

enum QuoteTaskStatus {
  NOT_READY
  READY
  IN_PROGRESS
  BLOCKED
  WAITING
  NEEDS_REVIEW
  COMPLETE
  SKIPPED
  CANCELED
}

enum QuoteAssumptionVisibility {
  CUSTOMER_VISIBLE
  INTERNAL_ONLY
}

enum OpportunityPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OpportunityTaskStatus {
  NOT_READY
  READY
  IN_PROGRESS
  WAITING
  BLOCKED
  NEEDS_REVIEW
  COMPLETE
  CANCELED
}

enum OpportunityTaskKind {
  INTAKE
  SITE_VISIT
  REVIEW
  FOLLOW_UP
  OTHER
}

/// Organization-owned reusable quote/work blocks (copy-only seeds; not live dependencies).
enum QuoteWorkTemplateKind {
  LINE_ITEM_WITH_PLAN
  STAGE_WITH_TASKS
  TASK
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())

  memberships               Membership[]
  auditEvents               AuditEvent[]
  customers                 Customer[]
  opportunities             Opportunity[]
  opportunityActivityEvents OpportunityActivityEvent[]
  quotes                    Quote[]
  quoteLineItems               QuoteLineItem[]
  quoteTasks                   QuoteTask[]
  quoteLineExecutionStages     QuoteLineExecutionStage[]
  quoteLineExecutionTasks      QuoteLineExecutionTask[]
  quoteAssumptions             QuoteAssumption[]
  quoteActivityEvents          QuoteActivityEvent[]
  quoteWorkTemplates           QuoteWorkTemplate[]
  jobs                         Job[]
  jobLines                     JobLine[]
  jobStages                    JobStage[]
  jobTasks                     JobTask[]
  jobActivityEvents            JobActivityEvent[]
  scheduledWorks               ScheduledWork[]
  portalAccessTokens           PortalAccessToken[]
  customerPortalSubmissions    CustomerPortalSubmission[]
  customerPortalSubmissionAttachments CustomerPortalSubmissionAttachment[]
  jobEvidences                 JobEvidence[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())

  memberships               Membership[]
  accounts                  Account[]
  sessions                  Session[]
  salesOwnedOpportunities   Opportunity[]              @relation("OpportunitySalesOwner")
  assignedOpportunityTasks  OpportunityTask[]          @relation("OpportunityTaskAssignee")
  opportunityActivityEvents OpportunityActivityEvent[] @relation("OpportunityActivityActor")
  quotesCreated             Quote[]                    @relation("QuoteCreatedBy")
  quotesOwned               Quote[]                    @relation("QuoteOwner")
  quotesAccepted            Quote[]                    @relation("QuoteAcceptedBy")
  quotesActivated           Quote[]                    @relation("QuoteActivatedBy")
  jobsActivated             Job[]                      @relation("JobActivatedBy")
  quoteWorkTemplatesCreated QuoteWorkTemplate[]        @relation("QuoteWorkTemplateCreatedBy")
  jobActivityEventsActed    JobActivityEvent[]         @relation("JobActivityActor")
  jobTasksLastStatusChanged JobTask[]                  @relation("JobTaskLastStatusChangedBy")
  jobTasksCompleted         JobTask[]                  @relation("JobTaskCompletedBy")
  scheduledWorksCreated     ScheduledWork[]            @relation("ScheduledWorkCreatedBy")
  scheduledWorksCanceled    ScheduledWork[]            @relation("ScheduledWorkCanceledBy")
  portalAccessTokensCreated PortalAccessToken[]        @relation("PortalAccessTokenCreatedBy")
  reviewedPortalSubmissions CustomerPortalSubmission[] @relation("PortalSubmissionReviewedBy")
  jobEvidencePromoted        JobEvidence[]             @relation("JobEvidencePromotedBy")
  jobEvidenceReviewed        JobEvidence[]             @relation("JobEvidenceReviewedBy")
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  type           String
  payload        Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([type, createdAt])
}

model Customer {
  id             String         @id @default(cuid())
  organizationId String
  displayName    String
  kind           CustomerKind   @default(UNKNOWN)
  status         CustomerStatus @default(ACTIVE)
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactMethods CustomerContactMethod[]
  opportunities  Opportunity[]
  activityEvents OpportunityActivityEvent[]
  quotes           Quote[]
  jobs             Job[]
  portalAccessTokens         PortalAccessToken[]
  customerPortalSubmissions  CustomerPortalSubmission[]

  @@index([organizationId])
  @@index([organizationId, updatedAt])
}

model CustomerContactMethod {
  id         String              @id @default(cuid())
  customerId String
  type       CustomerContactType
  value      String
  isPrimary  Boolean             @default(false)
  okToEmail  Boolean             @default(false)
  okToSms    Boolean             @default(false)
  label      String?
  archivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([customerId, archivedAt])
}

model Opportunity {
  id                  String              @id @default(cuid())
  organizationId      String
  customerId          String
  title               String
  serviceType         String
  source              String
  status              OpportunityStatus   @default(NEW)
  priority            OpportunityPriority @default(NORMAL)
  serviceAddressText  String?             @db.Text
  serviceAddressTbd   Boolean             @default(false)
  contactIntakeWaived Boolean             @default(false)
  scopeIntent         String              @db.Text
  desiredTimeline     String?             @db.Text
  salesOwnerUserId    String?
  qualificationStatus String?
  estimatedValue      Decimal?            @db.Decimal(12, 2)
  lostReason          String?             @db.Text
  noQuoteReason       String?             @db.Text
  followUpAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesOwner     User?                      @relation("OpportunitySalesOwner", fields: [salesOwnerUserId], references: [id], onDelete: SetNull)
  tasks          OpportunityTask[]
  activityEvents OpportunityActivityEvent[]
  quotes         Quote[]
  jobs           Job[]

  @@index([organizationId])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
}

model Quote {
  id                   String        @id @default(cuid())
  organizationId     String
  customerId         String
  opportunityId      String
  displayNumber        Int
  status               QuoteStatus   @default(DRAFT)
  title                String
  serviceAddressText   String?       @db.Text
  serviceAddressTbd    Boolean       @default(false)
  scopeIntent          String        @db.Text
  scopeSummary         String?       @db.Text
  customerFacingIntro  String?       @db.Text
  internalNotes        String?       @db.Text
  pricingSubtotalCents Int?
  totalCents           Int?
  sentAt               DateTime?
  sentSnapshotJson     Json?
  acceptedAt           DateTime?
  acceptedByUserId     String?
  activatedAt          DateTime?
  activatedByUserId    String?
  createdById          String
  ownerUserId          String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  opportunity  Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  createdBy    User         @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  owner        User?        @relation("QuoteOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  acceptedBy   User?        @relation("QuoteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  activatedBy  User?        @relation("QuoteActivatedBy", fields: [activatedByUserId], references: [id], onDelete: SetNull)
  /// Denormalized link to Job.id after activation (same row as `job` via Job.quoteId).
  jobId        String?      @unique
  job          Job?

  lineItems    QuoteLineItem[]
  tasks        QuoteTask[]
  assumptions  QuoteAssumption[]
  activityEvents QuoteActivityEvent[]
  portalAccessTokens           PortalAccessToken[]
  customerPortalSubmissions    CustomerPortalSubmission[]

  @@unique([organizationId, displayNumber])
  @@index([organizationId])
  @@index([organizationId, opportunityId])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
}

model Job {
  id                 String    @id @default(cuid())
  organizationId     String
  quoteId            String    @unique
  customerId         String
  opportunityId      String?
  displayNumber      Int
  title              String
  status             JobStatus @default(WORK_PLAN_REVIEW)
  sourceSnapshotJson Json
  activationBaselineJson Json?
  activatedAt        DateTime?
  activatedByUserId  String?
  /// Pause/cancel context; cleared on resume (when it held pause note) and on complete.
  statusReason       String?   @db.Text
  pausedAt           DateTime?
  completedAt        DateTime?
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote         Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  activatedBy   User?        @relation("JobActivatedBy", fields: [activatedByUserId], references: [id], onDelete: SetNull)
  lines         JobLine[]
  stages         JobStage[]
  tasks          JobTask[]
  activityEvents JobActivityEvent[]
  scheduledWorks             ScheduledWork[]
  portalAccessTokens         PortalAccessToken[]
  customerPortalSubmissions  CustomerPortalSubmission[]
  jobEvidences               JobEvidence[]

  @@unique([organizationId, displayNumber])
  @@index([organizationId])
  @@index([organizationId, customerId])
  @@index([organizationId, quoteId])
  @@index([organizationId, status])
}

/// Append-only staff job history. Never expose in customer-facing projections.
model JobActivityEvent {
  id             String   @id @default(cuid())
  organizationId String
  jobId          String
  actorUserId    String?
  eventType      String
  summary        String   @db.Text
  payloadJson    Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation("JobActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, jobId])
  @@index([organizationId, createdAt])
  @@index([organizationId, jobId, createdAt])
}

model JobLine {
  id                    String   @id @default(cuid())
  organizationId        String
  jobId                 String
  sourceQuoteLineItemId String?
  title                 String
  customerDescription   String?  @db.Text
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stages       JobStage[]
  tasks        JobTask[]

  @@index([organizationId])
  @@index([organizationId, jobId])
}

model JobStage {
  id                 String   @id @default(cuid())
  organizationId     String
  jobId              String
  jobLineId          String
  sourceQuoteStageId String?
  title              String
  sortOrder          Int      @default(0)
  internalNotes      String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobLine      JobLine      @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  tasks        JobTask[]

  @@index([organizationId])
  @@index([organizationId, jobId])
  @@index([organizationId, jobLineId])
}

model JobTask {
  id                         String        @id @default(cuid())
  organizationId             String
  jobId                      String
  jobLineId                  String
  jobStageId                 String
  sourceQuoteTaskId          String?
  title                      String
  description                String?       @db.Text
  status                     JobTaskStatus @default(NOT_STARTED)
  isRequired                 Boolean       @default(false)
  sortOrder                  Int           @default(0)
  assignedRole               String?
  estimatedDurationMinutes   Int?
  customerVisible            Boolean       @default(false)
  customerLabel              String?
  internalNotes              String?       @db.Text
  blockedReason              String?       @db.Text
  lastStatusChangedAt        DateTime?
  lastStatusChangedByUserId  String?
  completedAt                DateTime?
  completedByUserId          String?
  completionRequirementsJson Json?
  /// Soft-archive during work plan review; excluded from execution feeds and activation baseline.
  archivedAt                 DateTime?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobLine            JobLine      @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  jobStage           JobStage     @relation(fields: [jobStageId], references: [id], onDelete: Cascade)
  lastStatusChangedBy User?     @relation("JobTaskLastStatusChangedBy", fields: [lastStatusChangedByUserId], references: [id], onDelete: SetNull)
  completedBy         User?     @relation("JobTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  scheduledWorks      ScheduledWork[]
  jobEvidences        JobEvidence[]

  @@index([organizationId])
  @@index([organizationId, jobId])
  @@index([organizationId, jobStageId])
}

/// Staff-controlled job evidence (promoted from portal intake or future sources). Not customer-trusted until accepted.
model JobEvidence {
  id                 String            @id @default(cuid())
  organizationId     String
  jobId              String
  jobTaskId          String?
  sourceAttachmentId String?
  status             JobEvidenceStatus @default(CANDIDATE)
  title              String
  description        String?           @db.Text
  promotedByUserId   String?
  promotedAt         DateTime          @default(now())
  reviewedByUserId   String?
  reviewedAt         DateTime?
  rejectionReason    String?           @db.Text
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  organization     Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job              Job                                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobTask          JobTask?                           @relation(fields: [jobTaskId], references: [id], onDelete: SetNull)
  sourceAttachment CustomerPortalSubmissionAttachment? @relation(fields: [sourceAttachmentId], references: [id], onDelete: SetNull)
  promotedBy       User?                              @relation("JobEvidencePromotedBy", fields: [promotedByUserId], references: [id], onDelete: SetNull)
  reviewedBy       User?                              @relation("JobEvidenceReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, jobId])
  @@index([organizationId, jobTaskId])
  @@index([organizationId, status])
  @@index([organizationId, sourceAttachmentId])
}

/// Time window for job execution work. Readiness is derived from Job/JobTask facts — not stored here.
model ScheduledWork {
  id               String              @id @default(cuid())
  organizationId   String
  jobId            String
  jobTaskId        String
  type             ScheduledWorkType   @default(JOB_TASK)
  status           ScheduledWorkStatus @default(SCHEDULED)
  title            String
  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  notes            String?             @db.Text
  createdByUserId  String?
  canceledAt       DateTime?
  canceledByUserId String?
  cancelReason     String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobTask      JobTask      @relation(fields: [jobTaskId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ScheduledWorkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  canceledBy   User?       @relation("ScheduledWorkCanceledBy", fields: [canceledByUserId], references: [id], onDelete: SetNull)
  customerPortalSubmissions CustomerPortalSubmission[]

  @@index([organizationId])
  @@index([organizationId, scheduledStartAt])
  @@index([organizationId, jobId])
  @@index([organizationId, jobTaskId])
  @@index([organizationId, status])
}

/// Customer portal capability: raw token is never stored; only SHA-256 hash of the high-entropy secret.
model PortalAccessToken {
  id              String    @id @default(cuid())
  organizationId  String
  customerId      String
  quoteId         String
  jobId           String?
  tokenHash       String    @unique
  label           String?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdByUserId String?
  lastViewedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("PortalAccessTokenCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions  CustomerPortalSubmission[]

  @@index([organizationId])
  @@index([organizationId, customerId])
  @@index([organizationId, quoteId])
  @@index([organizationId, jobId])
}

/// DB-backed rate limits for unauthenticated portal POST actions. `key` is derived from portal token hash, never raw token.
model PortalActionRateLimit {
  id          String   @id @default(cuid())
  key         String
  action      String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, action, windowStart])
  @@index([key])
  @@index([windowStart])
}

/// Customer-originated portal notes. Source of review truth; not a chat thread.
model CustomerPortalSubmission {
  id                   String                         @id @default(cuid())
  organizationId       String
  customerId           String
  quoteId              String?
  jobId                String?
  scheduledWorkId      String?
  portalAccessTokenId  String?
  type                 CustomerPortalSubmissionType
  status               CustomerPortalSubmissionStatus @default(NEW)
  subject              String?
  message              String                         @db.Text
  payloadJson          Json?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quote              Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  job                Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)
  scheduledWork      ScheduledWork?      @relation(fields: [scheduledWorkId], references: [id], onDelete: SetNull)
  portalAccessToken  PortalAccessToken?  @relation(fields: [portalAccessTokenId], references: [id], onDelete: SetNull)
  reviewedBy         User?               @relation("PortalSubmissionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  attachments        CustomerPortalSubmissionAttachment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, jobId])
  @@index([organizationId, quoteId])
  @@index([organizationId, customerId])
  @@index([organizationId, createdAt])
}

/// Customer portal file intake. Binary bytes live in private object storage; `storageKey` is internal-only.
model CustomerPortalSubmissionAttachment {
  id                   String                                   @id @default(cuid())
  organizationId       String
  submissionId         String
  storageKey           String
  originalFilename     String
  sanitizedFilename    String?
  contentType          String
  detectedContentType  String?
  sizeBytes            Int
  checksumSha256       String?
  status               CustomerPortalSubmissionAttachmentStatus @default(STORED)
  createdAt            DateTime                                 @default(now())
  updatedAt            DateTime                                 @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submission   CustomerPortalSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  jobEvidences JobEvidence[]

  @@index([organizationId])
  @@index([organizationId, submissionId])
  @@index([organizationId, status])
}

model QuoteLineItem {
  id                  String       @id @default(cuid())
  organizationId    String
  quoteId             String
  title               String
  customerDescription String       @db.Text
  quantity            Decimal      @db.Decimal(12, 4)
  unitPriceCents      Int?
  lineTotalCents      Int?
  pricingMode         PricingMode
  sortOrder           Int          @default(0)
  lineMode            QuoteLineMode @default(REQUIRED)
  internalNotes       String?      @db.Text
  /// Informational only: line was created from a template insert (no live FK).
  sourceTemplateId       String?
  sourceTemplateKind     QuoteWorkTemplateKind?
  sourceTemplateVersion  Int?
  sourceTemplateName     String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote             Quote                    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  assumptions       QuoteAssumption[]
  executionStages   QuoteLineExecutionStage[]

  @@index([organizationId])
  @@index([quoteId])
  @@index([organizationId, quoteId])
}

model QuoteWorkTemplate {
  id               String                @id @default(cuid())
  organizationId String
  kind             QuoteWorkTemplateKind
  name             String
  description      String?               @db.Text
  tagsJson         Json?
  payloadVersion   Int                   @default(1)
  contentVersion   Int                   @default(1)
  payloadJson      Json
  archivedAt       DateTime?
  createdById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("QuoteWorkTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, kind])
  @@index([organizationId, archivedAt])
}

/// Quoted execution plan grouping for a line item (dormant until a future job phase). Template-friendly: quote-owned rows, no live template FK.
model QuoteLineExecutionStage {
  id               String   @id @default(cuid())
  organizationId   String
  quoteLineItemId  String
  title            String
  sortOrder        Int      @default(0)
  internalNotes    String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteLineItem QuoteLineItem   @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  tasks         QuoteLineExecutionTask[]

  @@index([organizationId])
  @@index([quoteLineItemId])
  @@index([organizationId, quoteLineItemId])
}

/// Dormant quoted execution step under a stage. Same status vocabulary as quote-prep tasks for consistency.
model QuoteLineExecutionTask {
  id                       String          @id @default(cuid())
  organizationId         String
  stageId                String
  title                  String
  description            String?         @db.Text
  status                   QuoteTaskStatus @default(NOT_READY)
  isRequired               Boolean         @default(false)
  sortOrder                Int             @default(0)
  assignedRole             String?
  estimatedDurationMinutes Int?
  customerVisible          Boolean         @default(false)
  customerLabel            String?
  internalNotes            String?         @db.Text
  /// Planned runtime completion gate (strict v1 JSON). Frozen into sent snapshot; not customer-facing.
  completionRequirementsJson Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage        QuoteLineExecutionStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stageId])
}

/// Internal quote-prep / sales-admin checklist only (never job execution).
model QuoteTask {
  id                       String           @id @default(cuid())
  organizationId         String
  quoteId                String
  kind                     QuoteTaskKind    @default(QUOTE_PREP)
  title                    String
  description              String?          @db.Text
  status                   QuoteTaskStatus  @default(NOT_READY)
  isRequired               Boolean          @default(false)
  sortOrder                Int              @default(0)
  assignedRole             String?
  estimatedDurationMinutes Int?
  customerVisible          Boolean          @default(false)
  customerLabel            String?
  internalNotes            String?          @db.Text
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([quoteId])
  @@index([organizationId, quoteId])
}

model QuoteAssumption {
  id             String                   @id @default(cuid())
  organizationId String
  quoteId        String
  quoteLineItemId String?
  visibility     QuoteAssumptionVisibility
  text           String                   @db.Text
  sortOrder      Int                      @default(0)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote         Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteLineItem QuoteLineItem? @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([quoteId])
}

model QuoteActivityEvent {
  id             String   @id @default(cuid())
  organizationId String
  quoteId        String
  opportunityId  String?
  customerId     String?
  actorUserId    String?
  eventType      String
  summary        String   @db.Text
  payload        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([organizationId, quoteId, createdAt])
  @@index([eventType, createdAt])
}

model OpportunityTask {
  id             String                @id @default(cuid())
  opportunityId  String
  title          String
  status         OpportunityTaskStatus @default(NOT_READY)
  kind           OpportunityTaskKind   @default(INTAKE)
  isRequired     Boolean               @default(false)
  dueAt          DateTime?
  assigneeUserId String?
  source         String                @default("MANUAL")
  outcome        String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("OpportunityTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([opportunityId, status])
}

model OpportunityActivityEvent {
  id              String   @id @default(cuid())
  organizationId  String
  opportunityId   String?
  customerId      String?
  eventType       String
  actorUserId     String?
  summary         String   @db.Text
  payload         Json?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity  Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  actor        User?        @relation("OpportunityActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, opportunityId, createdAt])
  @@index([organizationId, customerId, createdAt])
  @@index([eventType, createdAt])
}
