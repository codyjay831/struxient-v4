    "eslint": "^9.25.1",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
