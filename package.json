{
  "name": "struxient-v4",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:generate:clean": "node -e \"try{require('fs').rmSync('node_modules/.prisma',{recursive:true,force:true})}catch(e){}\" && prisma generate",
